{
  "expo": {
    "name": "Dohot",
    "slug": "dohot",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "dohot",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F3EE"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ronitwito.dohot",
      "buildNumber": "2",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "הקלטת קול ליצירת דוחות",
        "NSCameraUsageDescription": "צילום תמונות לדוח",
        "NSPhotoLibraryUsageDescription": "בחירת תמונות מהגלריה",
        "CFBundleDevelopmentRegion": "he",
        "CFBundleLocalizations": [
          "he"
        ]
      }
    },
    "android": {
      "versionCode": 2,
      "supportsRtl": true,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F3EE"
      },
      "package": "com.ronitwito.dohot",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "./plugins/withForceRTL",
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "צילום תמונות לדוח"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "הקלטת קול ליצירת דוחות"
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "בחירת תמונות מהגלריה לדוחות"
        }
      ],
      "expo-audio"
    ],
    "newArchEnabled": true,
    "runtimeVersion": "1.0.1",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "02af1aa6-b613-41a9-bc37-217b5830f41a"
      }
    },
    "owner": "zoharcohendev"
  }
}
