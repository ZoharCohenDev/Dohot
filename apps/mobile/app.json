{
  "expo": {
    "name": "Dohot",
    "slug": "dohot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "dohot",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F3EE"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ronitwito.dohot",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "הקלטת קול ליצירת דוחות",
        "NSCameraUsageDescription": "צילום תמונות לדוח",
        "NSPhotoLibraryUsageDescription": "בחירת תמונות מהגלריה"
      }
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F3EE"
      },
      "package": "com.ronitwito.dohot",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_MEDIA_IMAGES"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "צילום תמונות לדוח"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "הקלטת קול ליצירת דוחות"
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "בחירת תמונות מהגלריה לדוחות"
        }
      ],
      "expo-audio"
    ],
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
